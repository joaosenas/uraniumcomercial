# ===========================================
# Variáveis de Ambiente - PRODUÇÃO
# Uranium Company - Hub de Apresentações
# ===========================================

# Banco de Dados PostgreSQL (EasyPanel)
# Formato: postgresql://usuario:senha@host:porta/database
DATABASE_URL="postgresql://postgres:SUA_SENHA_DO_BANCO@postgres:5432/uranium_hub"

# NextAuth.js Secret
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET="COLE_AQUI_O_RESULTADO_DO_OPENSSL_RAND_BASE64_32"

# URL do Site (IMPORTANTE: URL completa com https://)
NEXTAUTH_URL="https://comercial.uraniumcompany.com.br"

# Ambiente
NODE_ENV="production"
